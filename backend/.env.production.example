ENVIRONMENT=production
APP_NAME=ExplainMyCode API
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/explainmycode
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8080
BACKEND_BASE_URL=http://localhost:8000
LLM_MODE=live
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Keep Judge0 first for production releases and leave the other execution API keys blank
# unless you intentionally want them to take precedence.
EXECUTION_PROVIDER_ORDER=judge0,onecompiler,compiler-io
ONECOMPILER_BASE_URL=https://api.onecompiler.com/v1/run
ONECOMPILER_API_KEY=
COMPILER_IO_BASE_URL=https://api.onlinecompiler.io/api/run-code-sync/
COMPILER_IO_API_KEY=
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=no-reply@example.com
SEED_DEMO_DATA=false
